load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "backend_lib",
    srcs = ["main.go"],
    importpath = "stempelkarte-backend",
    visibility = ["//visibility:private"],
    deps = [
        "//backend/auth",
        "//backend/db",
        "//backend/handlers",
        "//backend/middleware",
